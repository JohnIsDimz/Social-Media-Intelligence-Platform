rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    match /{document=**} {
      allow read, write: if false;
    }

    match /trackers/{trackerId} {
      allow read: if true;
      allow write: if true;
    }

    match /analyzed_posts/{postId} {
      allow read: if true;
      allow write: if true;
    }

    match /monitor_results/{resultId} {
      allow read: if true;
      allow write: if true;
    }
  }
}
